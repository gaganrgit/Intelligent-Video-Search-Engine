# ── Video Search Engine — Environment Configuration ──────────────────────────
# Copy this file to .env and adjust as needed.

# Model — swap for larger model for better accuracy (requires more VRAM)
# CLIP_MODEL=openai/clip-vit-large-patch14

# Device — leave empty for auto-detection (cuda if available, else cpu)
# DEVICE=cuda
# DEVICE=cpu

# Frame sampling
SAMPLE_FPS=1.0
USE_SCENE_DETECTION=true
SCENE_CHANGE_THRESHOLD=30.0

# Embedding batch size (reduce if OOM on CPU)
BATCH_SIZE=32

# FP16 inference (GPU only — set false on CPU)
USE_FP16=true

# FAISS index tuning
INDEX_NLIST=100
INDEX_NPROBE=10

# Query defaults
TOP_K=10
RERANK_TOP_K=50

# Server
HOST=0.0.0.0
PORT=8000
